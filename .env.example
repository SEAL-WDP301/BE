# ==========================================
# SEAL Backend - Environment Variables Example
# ==========================================
# Copy this file to .env.development or .env.production
# and fill in the actual values. NEVER commit .env files to git.

# ==========================================
# APPLICATION
# ==========================================
NODE_ENV=development                          # development | production
APP_PORT=3000                                 # Server port
APP_PREFIX=api                                # Global route prefix
FRONTEND_URL=http://localhost:3001            # Next.js dev server (npm run dev -p 3001)

# ==========================================
# SENTRY
# ==========================================
SENTRY_DSN=                                   # Project DSN from Sentry
SENTRY_ENABLED=true                           # Set false to disable without removing the DSN
SENTRY_ENVIRONMENT=development
SENTRY_ENABLE_LOGS=false
SENTRY_TRACES_SAMPLE_RATE=0.1                 # Range: 0.0 - 1.0
SENTRY_PROFILE_SESSION_SAMPLE_RATE=0.1        # Range: 0.0 - 1.0

# ==========================================
# DATABASE (PostgreSQL)
# ==========================================
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require

# ==========================================
# JWT Authentication
# ==========================================
JWT_ACCESS_SECRET=change_me_access_secret     # Min 32 chars in production
JWT_ACCESS_EXPIRES_IN=15m                     # Access token TTL (short-lived)
JWT_REFRESH_SECRET=change_me_refresh_secret   # Min 32 chars in production
JWT_REFRESH_EXPIRES_IN=7d                     # Refresh token TTL

# ==========================================
# REDIS Cache
# ==========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                               # Leave empty if no auth

# ==========================================
# GOOGLE OAUTH2
# Get credentials from: https://console.cloud.google.com
# ==========================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Google Calendar OAuth (separate consent flow for organizer calendars)
GOOGLE_CALENDAR_CLIENT_ID=your_google_calendar_client_id
GOOGLE_CALENDAR_CLIENT_SECRET=your_google_calendar_client_secret
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback
GOOGLE_CALENDAR_TOKEN_ENCRYPTION_KEY=change_me_to_a_random_value_with_at_least_32_characters

# ==========================================
# GITHUB OAUTH2
# Get credentials from: https://github.com/settings/developers
# ==========================================
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/github/callback

# ==========================================
# COOKIE
# ==========================================
COOKIE_SECRET=change_me_cookie_secret        # For signed cookies

# ==========================================
# GITHUB (Team repo provisioning — tạo repo khi approve team)
# Org test bài tập: https://github.com/HACKATHON-WDP
# Token fine-grained cần quyền Organization → Administration: Read and write
# ==========================================
GITHUB_TOKEN=your_github_pat_here
GITHUB_ORG=HACKATHON-WDP
# false = public repo (dev/demo: link mở được không cần login GitHub org)
# true  = private (production: bảo vệ source team, click link sẽ 404 nếu không có quyền)
GITHUB_REPO_PRIVATE=false
GITHUB_REPO_AUTO_INIT=true
