# ==========================================
# SEAL Backend - Environment Variables Example
# ==========================================
# Copy this file to .env.development or .env.production
# and fill in the actual values. NEVER commit .env files to git.

# ==========================================
# APPLICATION
# ==========================================
NODE_ENV=development                          # development | production
APP_PORT=3000                                 # Server port
APP_PREFIX=api                                # Global route prefix
FRONTEND_URL=http://localhost:5173            # Frontend URL for CORS & OAuth redirect
                              # Enable SSL for managed remote databases (true | false)

# ==========================================
# JWT Authentication
# ==========================================
JWT_ACCESS_SECRET=change_me_access_secret     # Min 32 chars in production
JWT_ACCESS_EXPIRES_IN=15m                     # Access token TTL (short-lived)
JWT_REFRESH_SECRET=change_me_refresh_secret   # Min 32 chars in production
JWT_REFRESH_EXPIRES_IN=7d                     # Refresh token TTL

# ==========================================
# REDIS Cache
# ==========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                               # Leave empty if no auth

# ==========================================
# GOOGLE OAUTH2
# Get credentials from: https://console.cloud.google.com
# ==========================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# ==========================================
# COOKIE
# ==========================================
COOKIE_SECRET=change_me_cookie_secret        # For signed cookies

# ==========================================
# GITHUB (Team repo provisioning — tạo repo khi approve team)
# Org test bài tập: https://github.com/HACKATHON-WDP
# Token fine-grained cần quyền Organization → Administration: Read and write
# ==========================================
GITHUB_TOKEN=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
GITHUB_ORG=HACKATHON-WDP
GITHUB_REPO_PRIVATE=true
GITHUB_REPO_AUTO_INIT=true
